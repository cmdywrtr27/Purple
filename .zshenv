export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export TERMINAL=alacritty
export EDITOR=vim
export VISUAL=vim
export SVN_EDITOR=vim
export BROWSER=brave
export FILEMANAGER=pcmanfm
export FZF_DEFAULT_OPS="--height 40% --prompt= --pointer= --marker= --ellipsis=..."
export PAGER=less
export LESS="-R"
export MANPAGER='/bin/zsh -c "vim -Rn -c \"set buftype=nofile showtabline=0 ft=man ts=4 nomod nolist nornu nonu noma\" -c \"normal L\" -c \"nmap q :qa<CR>\"</dev/tty <(col -b)"'

export PATH="/home/josh/.local/bin:$PATH"
export GOPATH=$HOME/.go
export PATH=$PATH:$GOROOT/bin:$GOPATH/bin

export ZSH_DIR=$HOME/.config/zsh
export ZSH_CACHEDIR=$HOME/.cache/zsh
export ZSH_THEMEDIR=$HOME/.config/zsh/themes
export ZSH_PLUGINDIR=$HOME/.config/zsh/plugins

eval $(dircolors -b)
export TERM=xterm-256color
#export LSCOLORS=gxBxhxDxfxhxhxhxhxcxcx

export QT_QPA_PLATFORMTHEME=qt5ct

export XDG_CONFIG_HOME=$HOME/.config
export XDG_CACHE_HOME=$HOME/.cache
export XDG_DATA_HOME=$HOME/.local/share

export WALLPAPERS_DIR=$HOME/Pictures/Wallpapers
export SCREENSHOTS_DIR=$HOME/Pictures/Screenshots
export SCRIPTS_DIR=$HOME/.local/bin

export LESSHISTFILE=$XDG_CACHE_HOME/less_history
export LESSHISTSIZE=500

